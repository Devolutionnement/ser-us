    "custom_liquid_npmAUi": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": true,
        "liquid": "<!-- ========= Lumoria | Review Slider (EN) ========= -->\n<div class=\"lumoria-reviews slider\">\n  <h3 class=\"slider-title\">\n    Customer reviews on the <span>Lumoria™</span> compression tank top\n  </h3>\n\n  <div class=\"nr-track\" id=\"nrTrack\">\n\n    <!-- CARD 1 -->\n    <article class=\"nr-item\">\n      <div class=\"nr-photo\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/image_2025-10-24_095301694.png?v=1761295925\"\n          loading=\"lazy\"\n          alt=\"Lumoria customer review — photo 1\">\n        <span class=\"nr-chip\">Lumoria</span>\n      </div>\n      <div class=\"nr-copy\">\n        <p class=\"nr-title\">Lucas D. — 34 years old</p>\n        <p class=\"nr-stars\" aria-label=\"5 stars out of 5\">★★★★★</p>\n        <p class=\"nr-text\">\n          \"At first I was skeptical. I always had that little belly I hid under shirts.\n          After 4 weeks with Lumoria, worn <strong>4 hours a day</strong>, I lost\n          <strong>5 cm off my waist</strong> and stood tall again.\n          My shoulders opened up and my girlfriend told me I \"shine more.\"\n          This isn't just a tank top — it's a constant reminder of who I want to be.\"\n        </p>\n      </div>\n    </article>\n\n    <!-- CARD 2 -->\n    <article class=\"nr-item\">\n      <div class=\"nr-photo\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/image_2025-10-24_095503368.png?v=1761296045\"\n          loading=\"lazy\"\n          alt=\"Lumoria customer review — photo 2\">\n        <span class=\"nr-chip\">Lumoria</span>\n      </div>\n      <div class=\"nr-copy\">\n        <p class=\"nr-title\">Martin R. — 42 years old</p>\n        <p class=\"nr-stars\" aria-label=\"5 stars out of 5\">★★★★★</p>\n        <p class=\"nr-text\">\n          \"I sit all day: hunched back, bloated stomach, zero confidence.\n          <strong>Lumoria</strong> forced me to straighten up without even thinking about it.\n          In <strong>10 days</strong>, less back pain and shirts fit better.\n          I wear it at the office: <strong>discreet</strong>, <strong>breathable</strong> and most importantly…\n          I stopped hiding in photos.\"\n        </p>\n      </div>\n    </article>\n\n    <!-- CARD 3 -->\n    <article class=\"nr-item\">\n      <div class=\"nr-photo\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/image_2025-10-24_095559592.png?v=1761296103\"\n          loading=\"lazy\"\n          alt=\"Lumoria customer review — photo 3\">\n        <span class=\"nr-chip\">Lumoria</span>\n      </div>\n      <div class=\"nr-copy\">\n        <p class=\"nr-title\">James L. — 27 years old</p>\n        <p class=\"nr-stars\" aria-label=\"5 stars out of 5\">★★★★★</p>\n        <p class=\"nr-text\">\n          \"After a shoulder injury I lost my physique.\n          Lumoria helped me <strong>reclaim my V-shape</strong> without pain.\n          I wear it at the gym and around town: <strong>comfortable compression</strong>,\n          core support, no breathing issues.\n          I got back that feeling of <strong>quiet strength</strong> I had lost.\"\n        </p>\n      </div>\n    </article>\n\n    <!-- CARD 4 -->\n    <article class=\"nr-item\">\n      <div class=\"nr-photo\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/hf_20260221_030705_dba00b9d-7a79-4f07-b47f-6befe9e42184.jpg?v=1771646041\"\n          loading=\"lazy\"\n          alt=\"Lumoria customer review — Thomas B.\">\n        <span class=\"nr-chip\">Lumoria</span>\n      </div>\n      <div class=\"nr-copy\">\n        <p class=\"nr-title\">Thomas B. — 38 years old</p>\n        <p class=\"nr-stars\" aria-label=\"5 stars out of 5\">★★★★★</p>\n        <p class=\"nr-text\">\n          \"For 3 years I turned down events because I didn't know what to wear.\n          Before every occasion I'd spend a week anxious about it.\n          Lumoria is the first time I stopped <strong>fighting my own reflection</strong>.\n          This morning I got dressed in <strong>5 minutes</strong>. No adjusting. No avoiding the mirror.\n          Sounds like nothing. But it's everything.\"\n        </p>\n      </div>\n    </article>\n\n    <!-- CARD 5 -->\n    <article class=\"nr-item\">\n      <div class=\"nr-photo\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/hf_20260221_035428_0b24fad6-648e-4d69-9d71-1631ea650283.jpg?v=1771646221\"\n          loading=\"lazy\"\n          alt=\"Lumoria customer review — George P.\">\n        <span class=\"nr-chip\">Lumoria</span>\n      </div>\n      <div class=\"nr-copy\">\n        <p class=\"nr-title\">George P. — 29 years old</p>\n        <p class=\"nr-stars\" aria-label=\"5 stars out of 5\">★★★★★</p>\n        <p class=\"nr-text\">\n          \"For years I wore <strong>two shirts</strong> layered on top of each other. In summer I'd sweat twice as much.\n          But I was too ashamed to take off the top layer.\n          Lumoria put an end to that. <strong>One layer</strong>, invisible under a white t-shirt,\n          and for the first time in forever I spent a whole afternoon on a terrace\n          <strong>without thinking about my chest once</strong>.\n          A terrace. A silly little win. But it's mine.\"\n        </p>\n      </div>\n    </article>\n\n    <!-- CARD 6 -->\n    <article class=\"nr-item\">\n      <div class=\"nr-photo\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/hf_20260221_035651_83ebd5c2-b480-48bb-a775-0d00ff5f03a1.jpg?v=1771646287\"\n          loading=\"lazy\"\n          alt=\"Lumoria customer review — Paul R.\">\n        <span class=\"nr-chip\">Lumoria</span>\n      </div>\n      <div class=\"nr-copy\">\n        <p class=\"nr-title\">Paul R. — 45 years old</p>\n        <p class=\"nr-stars\" aria-label=\"5 stars out of 5\">★★★★★</p>\n        <p class=\"nr-text\">\n          \"My son got married in June. I bought a suit two sizes too big to \"hide.\"\n          My wife saw me ordering Lumoria and said nothing.\n          On the wedding day I wore a suit <strong>in my actual size</strong>.\n          In the photos I'm standing straight. Genuinely smiling.\n          My son told me: <em>\"Dad, you look like the boss.\"</em>\n          I'm 45. For the first time I'm not hiding in a family photo.\n          <strong>First time.</strong>\"\n        </p>\n      </div>\n    </article>\n\n  </div>\n\n  <style>\n    .lumoria-reviews{\n      --nr-brand:#0d1b2a;\n      --nr-ink:#111;\n      --nr-muted:#6b7280;\n      --nr-radius:16px;\n      --nr-shadow:0 8px 24px rgba(13,27,42,.12);\n      margin-left:16px;\n    }\n    .lumoria-reviews .slider-title{\n      margin:0 0 14px 4px;\n      font-weight:800;\n      font-size:18px;\n      color:var(--nr-ink);\n    }\n    .lumoria-reviews .slider-title span{ color:var(--nr-brand); }\n    .lumoria-reviews .nr-track{\n      display:grid;\n      grid-auto-flow:column;\n      grid-auto-columns:minmax(280px,85%);\n      gap:18px;\n      overflow-x:auto;\n      scroll-snap-type:x mandatory;\n      scroll-behavior:smooth;\n      -webkit-overflow-scrolling:touch;\n      padding:4px 2px 12px 2px;\n    }\n    .lumoria-reviews .nr-track::-webkit-scrollbar{ height:0; }\n    .lumoria-reviews .nr-item{\n      scroll-snap-align:start;\n      background:#fff;\n      border-radius:var(--nr-radius);\n    }\n    .lumoria-reviews .nr-photo{\n      position:relative;\n      border-radius:var(--nr-radius);\n      overflow:hidden;\n      box-shadow:var(--nr-shadow);\n      aspect-ratio:4/5;\n      background:#f6f8fb;\n    }\n    .lumoria-reviews .nr-photo img{\n      width:100%;\n      height:100%;\n      object-fit:cover;\n      display:block;\n    }\n    .lumoria-reviews .nr-chip{\n      position:absolute;\n      top:10px;\n      left:50%;\n      transform:translateX(-50%);\n      background:var(--nr-brand);\n      color:#fff;\n      font-size:11px;\n      font-weight:800;\n      padding:6px 10px;\n      border-radius:999px;\n      letter-spacing:.2px;\n    }\n    .lumoria-reviews .nr-copy{\n      text-align:left;\n      padding:12px 8px 10px;\n    }\n    .lumoria-reviews .nr-title{\n      font-weight:800;\n      font-size:17px;\n      line-height:1.3;\n      margin:6px 0 6px;\n      color:var(--nr-ink);\n    }\n    .lumoria-reviews .nr-stars{\n      margin:0 0 6px;\n      font-size:14px;\n      letter-spacing:2px;\n      color:#111;\n    }\n    .lumoria-reviews .nr-text{\n      color:var(--nr-ink);\n      opacity:.92;\n      font-size:15px;\n      line-height:1.55;\n      margin:0;\n    }\n    .lumoria-reviews .nr-text strong{ font-weight:800; }\n    @media (min-width:700px){\n      .lumoria-reviews .nr-track{ grid-auto-columns:minmax(300px,55%); }\n      .lumoria-reviews{ margin-left:22px; }\n    }\n    @media (min-width:1000px){\n      .lumoria-reviews .nr-track{ grid-auto-columns:340px; }\n      .lumoria-reviews{ margin-left:28px; }\n    }\n    @media (max-width:480px){\n      .lumoria-reviews{ margin-left:12px; }\n      .lumoria-reviews .slider-title{ font-size:17px; }\n    }\n  </style>\n</div>\n<!-- ===== /Lumoria | Review Slider EN ===== -->",
