        "liquid": "<style>\n@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@700&display=swap');\n.tr-bar {\n  font-family: 'Poppins', sans-serif;\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  background: #fff;\n  border-top: 1px solid #ebebeb;\n  border-bottom: 1px solid #ebebeb;\n  padding: 30px 20px;\n}\n.tr-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  text-align: center;\n  padding: 0 10px;\n  border-right: 1px solid #ebebeb;\n}\n.tr-item:last-child { border-right: none; }\n.tr-icon {\n  width: 64px;\n  height: 64px;\n  background: #f0f4ff;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-bottom: 14px;\n  flex-shrink: 0;\n}\n.tr-icon svg { width: 32px; height: 32px; }\n.tr-label {\n  font-size: 14px;\n  font-weight: 700;\n  color: #111;\n  line-height: 1.4;\n}\n@media (max-width: 600px) {\n  .tr-bar { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px 0; padding: 24px 12px; }\n  .tr-item:nth-child(2) { border-right: none; }\n  .tr-item:nth-child(3) { border-right: 1px solid #ebebeb; }\n  .tr-icon { width: 56px; height: 56px; }\n  .tr-icon svg { width: 28px; height: 28px; }\n  .tr-label { font-size: 13px; }\n}\n</style>\n\n<div class=\"tr-bar\">\n\n  <div class=\"tr-item\">\n    <div class=\"tr-icon\">\n      <svg viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M0 3.75156C0 3.47454 0.224196 3.24997 0.500755 3.24997H10.647C10.9235 3.24997 11.1477 3.47454 11.1477 3.75156V13.6616C10.9427 14.0067 10.8813 14.1101 10.5516 14.6648L7.22339 14.6646V13.6614H10.1462V4.25316H1.00151V13.6614H2.6842V14.6646H0.500755C0.224196 14.6646 0 14.44 0 14.163V3.75156Z\" fill=\"#1a4fd8\"/>\n        <path d=\"M18.9985 8.08376L11.1477 6.10938V5.07505L19.6212 7.20603C19.8439 7.26203 20 7.46255 20 7.69253V14.1631C20 14.4401 19.7758 14.6647 19.4992 14.6647H17.3071V13.6615H18.9985V8.08376ZM11.1477 13.6616L13.