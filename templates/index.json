idden;\n    flex-shrink: 0;\n    box-shadow: 0 0 0 1px #f5cfe0;\n  }\n  .ser-avatar:first-child { margin-left: 0; }\n  .ser-avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }\n  .ser-avatar-more {\n    width: 32px; height: 32px;\n    border-radius: 50%;\n    border: 2px solid #fff;\n    margin-left: -8px;\n    background: #e8a4be;\n    font-size: 11px;\n    font-weight: 700;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: #fff;\n    flex-shrink: 0;\n  }\n  .ser-proof-text { font-size: 12.5px; color: #7b5a6b; font-weight: 600; }\n  .ser-proof-text strong { color: #1a0a12; }\n  .ser-stars {\n    display: flex;\n    align-items: center;\n    gap: 2px;\n    margin-bottom: 22px;\n    justify-content: center;\n  }\n  .ser-star {\n    width: 14px; height: 14px;\n    background: #e8a4be;\n    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);\n  }\n  .ser-stars span { font-size: 12.5px; color: #7b5a6b; font-weight: 600; margin-left: 4px; }\n  .ser-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 10px;\n    background: #c97fa8;\n    color: #fff !important;\n    font-family: 'Poppins', sans-serif;\n    font-size: 17px;\n    font-weight: 800;\n    padding: 20px 32px;\n    border-radius: 14px;\n    width: 100%;\n    border: none;\n    cursor: pointer;\n    text-decoration: none;\n    box-shadow: 0 8px 24px rgba(201,127,168,0.3);\n    letter-spacing: -0.2px;\n    transition: transform 0.15s, box-shadow 0.15s;\n  }\n  .ser-btn:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 12px 32px rgba(201,127,168,0.38);\n    color: #fff !important;\n  }\n  .ser-btn-arrow {\n    background: rgba(255,255,255,0.2);\n    border-radius: 50%;\n    width: 28px; height: 28px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 14px;\n    flex-shrink: 0;\n  }\n  .ser-hint { font-size: 12px; color: #b09aa8; margin-top: 10px; font-weight: 500; }\n  .ser-divider { width: 100%; height: 1px; background: #faeef4; margin: 18px 0; }\n  .ser-trust {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 6px;\n    flex-wrap: wrap;\n  }\n  .ser-trust-item {\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    font-size: 12px;\n    color: #7b5a6b;\n    font-weight: 600;\n  }\n  .ser-dot { width: 6px; height: 6px; border-radius: 50%; background: #c97fa8; flex-shrink: 0; }\n  .ser-sep { color: #f5cfe0; font-size: 12px; }\n</style>\n\n<div class=\"ser-cta\">\n  <div class=\"ser-badge\">\n    <span class=\"ser-pulse\"></span>\n    Limited stock available\n  </div>\n  <h2>Stop hiding.<br>Start glowing with confidence.</h2>\n  <p>Join 32,200+ women who transformed their silhouette and fell in love with how they look — from the very first wear.</p>\n  <div class=\"ser-proof\">\n    <div class=\"ser-avatars\">\n      <div class=\"ser-avatar\"><img src=\"https://randomuser.me/api/portraits/women/44.jpg\" alt=\"\" /></div>\n      <div class=\"ser-avatar\"><img src=\"https://randomuser.me/api/portraits/women/68.jpg\" alt=\"\" /></div>\n      <div class=\"ser-avatar\"><img src=\"https://randomuser.me/api/portraits/women/21.jpg\" alt=\"\" /></div>\n      <div class=\"ser-avatar-more\">+</div>\n    </div>\n    <span class=\"ser-proof-text\"><strong>32,200+</strong> women already in</span>\n  </div>\n  <div class=\"ser-stars\">\n    <div class=\"ser-star\"></div>\n    <div class=\"ser-star\"></div>\n    <div class=\"ser-star\"></div>\n    <div class=\"ser-star\"></div>\n    <div class=\"ser-star\"></div>\n    <span>4.8 · 9,800+ reviews</span>\n  </div>\n  <a href=\"#\" class=\"ser-btn\">\n    Get my Shapova\n    <span class=\"ser-btn-arrow\">→</span>\n  </a>\n  <span class=\"ser-hint\">View full details, reviews & before/after results</span>\n  <div class=\"ser-divider\"></div>\n  <div class=\"ser-trust\">\n    <span class=\"ser-trust-item\"><span class=\"ser-dot\"></span>Free shipping</span>\n    <span class=\"ser-sep\">·</span>\n    <span class=\"ser-trust-item\"><span class=\"ser-dot\"></span>45-day guarantee</span>\n    <span class=\"ser-sep\">·</span>\n    <span class=\"ser-trust-item\"><span class=\"ser-dot\"></span>Secure payment</span>\n  </div>\n</div>",
