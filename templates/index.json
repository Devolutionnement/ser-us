        "liquid": "<div class=\"section section-blends section-full\" style=\"margin: 0;\">\n  <div class=\"tp-clean\">\n    <h2>Our customers say it best</h2>\n    <div class=\"tp-line\">\n      <span class=\"rating-text\">Excellent</span>\n      <strong class=\"rating-score\">4.7 / 5</strong>\n      <img\n        src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/stars-4.5-trust-pilot.svg?v=1760266880\"\n        alt=\"4.8 stars\"\n        class=\"stars-img\"\n        loading=\"lazy\">\n    </div>\n    <div class=\"tp-bottom\">\n      <span>Based on <strong>+9,800</strong> reviews</span>\n      <img\n        src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/trustpilot-svg_klyne.webp?v=1760266910\"\n        alt=\"Trustpilot\"\n        class=\"tp-logo\"\n        loading=\"lazy\">\n    </div>\n  </div>\n  <style>\n    .section-blends.section-full {\n      margin-top: 5px !important;\n      margin-bottom: 0 !important;\n      padding-top: 10px !important;\n      padding-bottom: 0 !important;\n      background-color: #fff;\n    }\n    .tp-clean {\n      text-align: center;\n      color: #000;\n      margin: 10px 0 !important;\n      padding: 0 !important;\n    }\n    .tp-clean h2 {\n      font-size: 22px;\n      font-weight: 700;\n      line-height: 1.5;\n      margin: 0 0 .8rem;\n      letter-spacing: .2px;\n    }\n    .tp-line {\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      gap: 8px;\n      margin-bottom: .5rem;\n      flex-wrap: wrap;\n    }\n    .rating-text,\n    .rating-score {\n      font-size: 16px;\n      line-height: 1;\n      display: inline-block;\n      vertical-align: middle;\n      margin-top: 2px;\n    }\n    .rating-score {\n      font-weight: 700;\n    }\n    .stars-img {\n      width: 120px;\n      max-width: 100%;\n      vertical-align: middle;\n      margin-right: 10px;\n      height: auto;\n    }\n    .tp-bottom {\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      gap: 8px;\n      font-size: 15px;\n      flex-wrap: wrap;\n    }\n    .tp-logo {\n      height: 24px;\n      width: auto;\n      margin-top: -2px;\n    }\n    @media (max-width: 480px) {\n      .tp-clean h2 { font-size: 20px; }\n      .rating-text, .rating-score { font-size: 15px; }\n      .tp-bottom { font-size: 14px; }\n      .stars-img { width: 112px; margin-right: 6px; }\n    }\n  </style>\n</div>",
