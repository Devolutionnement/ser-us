        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<div id=\"faq-contact-{{ section.id }}\" class=\"faq-contact page-width hide-desktop\">\n  <style>\n    #faq-contact-{{ section.id }} {\n      padding-bottom: 8px;\n    }\n    #faq-contact-{{ section.id }} .twibox {\n      display: flex;\n      align-items: flex-start;\n      gap: 14px;\n      background: #fff;\n      border: 1px solid #eaeaea;\n      border-radius: 12px;\n      padding: 16px 18px;\n    }\n    #faq-contact-{{ section.id }} .twibox h3 {\n      margin: 0 0 6px;\n      font-size: clamp(16px, 2.6vw, 18px);\n      line-height: 1.25;\n      font-weight: 700;\n      color: #111;\n    }\n    #faq-contact-{{ section.id }} .twibox p {\n      margin: 0;\n      color: #333;\n      font-size: 14px;\n      line-height: 1.5;\n    }\n    #faq-contact-{{ section.id }} .twibox a {\n      color: #111;\n      text-decoration: underline;\n      font-weight: 700;\n    }\n    #faq-contact-{{ section.id }} .twibox a:hover {\n      opacity: .75;\n    }\n    #faq-contact-{{ section.id }} .twibox .icon {\n      flex: 0 0 auto;\n      line-height: 0;\n    }\n    @media (min-width: 990px) {\n      #faq-contact-{{ section.id }} {\n        max-width: 960px;\n        margin: 0 auto;\n      }\n    }\n  </style>\n  <div class=\"twibox\" role=\"group\" aria-label=\"Help & contact\">\n    <div class=\"icon\" aria-hidden=\"true\">\n      <svg focusable=\"false\" role=\"presentation\" width=\"52\" height=\"53\" viewBox=\"0 0 52 53\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M21.638 22.7861H41.0321M21.638 27.5945H41.0321M21.638 32.4082H35.3808M45.9025 15.4028V39.7966H41.0321V45.2668L32.5268 39.7966H16.8296V15.4028H45.9025Z\" stroke=\"black\" stroke-width=\"1.03407\"/>\n        <path d=\"M34.8742 8.02979V15.4027H16.8296V33.9281L10.6717 37.8938V32.4184H5.80127V8.02979H34.8742Z\" stroke=\"black\" stroke-width=\"1.03407\"/>\n      </svg>\n    </div>\n    <div class=\"copy\">\n      <h3>Didn't find your answer?</h3>\n      <p>We're happy to help you <a href=\"https://fitlumoria.com/pages/contact\" title=\"Contact\">here</a>.</p>\n    </div>\n  </div>\n</div>",
